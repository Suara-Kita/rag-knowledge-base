# ─────────────────────────────────────────────
# Knowledge Base MCP Service
# ─────────────────────────────────────────────

# ─────────────────────────────────────────────
# Neo4j
# ─────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# ─────────────────────────────────────────────
# OpenRouter (OpenAI-compatible — use env vars
# so neo4j-graphrag picks them up automatically)
# ─────────────────────────────────────────────
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=sk-or-v1-
LLM_MODEL=openai/gpt-oss-120b
EMBEDDING_MODEL=google/gemini-embedding-2
EMBEDDING_DIMS=3072
VECTOR_INDEX_NAME=chunk_embeddings

# ─────────────────────────────────────────────
# Anthropic (entity/relationship extraction at
# ingestion time only — answer generation still
# uses LLM_MODEL above via OpenRouter)
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-
ENTITY_LLM_MODEL=claude-haiku-4-5-20251001

# ─────────────────────────────────────────────
# Watcher
# WATCH_DIR accepts a single path or a comma-separated
# list of paths to poll multiple markdown sources at once,
# e.g. ./watch,./watch-johor-economy,./watch-flood
# ─────────────────────────────────────────────
WATCH_DIR=./watch,./watch-johor-research
PROCESSED_DIR=./processed
WATCH_INTERVAL_MS=30000

# ─────────────────────────────────────────────
# Redis (for publishing unmatched onn-ai queries)
# ─────────────────────────────────────────────
REDIS_URL=redis://default:redis@localhost:6380

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL=INFO
